# Database
DATABASE_URL="postgresql://user:password@localhost:5432/db_name?schema=public"

# JWT
JWT_SECRET="generate-a-secure-random-secret-key"
JWT_EXPIRATION="8h"

# Server
PORT=3001
NODE_ENV=development

# CNPJ API
CNPJ_API_URL="https://brasilapi.com.br/api/cnpj/v1"

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH="./uploads"

# CORS
CORS_ORIGIN="http://localhost:3000"

# ─── Módulo Fiscal ──────────────────────────────────────────────────────────
# Certificado A1 (.pfx) para assinatura digital XMLDSIG
# Coloque o arquivo .pfx na raiz do projeto ou em /certs
CERT_PFX_PATH="./certs/certificado.pfx"
CERT_PFX_PASSWORD=""

# URL do portal principal que receberá os webhooks de NF-e/NFS-e
WEBHOOK_PORTAL_URL="http://localhost:3000/api/webhooks/fiscal"
