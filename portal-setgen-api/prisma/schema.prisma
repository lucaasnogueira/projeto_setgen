// ============================================
// RECURSOS HUMANOS (RH)
// ============================================

enum EmployeeStatus {
  ACTIVE
  AWAY
  VACATION
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum CivilStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  STABLE_UNION
}

enum ContractType {
  CLT
  PJ
  INTERN
  TEMPORARY
}

enum SalaryType {
  MONTHLY
  HOURLY
}

enum WorkRegime {
  PRESENTIAL
  HYBRID
  REMOTE
}

enum AccountType {
  CHECKING
  SAVINGS
}

enum HierarchicalLevel {
  TRAINEE
  JUNIOR
  MID
  SENIOR
  LEAD
  MANAGER
  DIRECTOR
  VP
  CEO
}

enum ASOType {
  ADMISSIONAL
  PERIODIC
  RETURN_TO_WORK
  CHANGE_OF_FUNCTION
  DISMISSAL
}

model Employee {
  id          String       @id @default(uuid())
  // ðŸ“Œ 1. Dados Pessoais
  name        String
  socialName  String?
  cpf         String       @unique
  rg          String?
  birthDate   DateTime?
  gender      Gender?
  civilStatus CivilStatus?
  nationality String?
  birthPlace  String?
  photoUrl    String?
  isPcd       Boolean      @default(false)
  pcdType     String?

  // ðŸ“Œ 2. Contato
  personalEmail  String? @unique
  corporateEmail String? @unique
  mobilePhone    String?
  landlinePhone  String?
  address        Json? // { cep, street, number, complement, neighborhood, city, state }

  // ðŸ“Œ 3. Dados Trabalhistas
  ctps                String?
  pisPasep            String?
  voterId             String?
  militaryCertificate String?
  admissionDate       DateTime?
  contractType        ContractType? @default(CLT)
  workHours           String? // Jornada de trabalho
  position            String? // Cargo
  department          String?
  costCenterId        String?
  costCenter          CostCenter?   @relation(fields: [costCenterId], references: [id])
  baseSalary          Decimal?      @db.Decimal(10, 2)
  salaryType          SalaryType?   @default(MONTHLY)
  workRegime          WorkRegime?   @default(PRESENTIAL)

  // ðŸ“Œ 4. Dados Financeiros
  bank         String?
  agency       String?
  account      String?
  accountType  AccountType?
  pixKey       String?
  irDependents Int          @default(0)
  benefitsPlan Json? // [ { type: 'VT', value: 100 }, ... ]

  // ðŸ“Œ 5. Estrutura Organizacional
  registration      String?            @unique // MatrÃ­cula
  managerId         String?
  manager           Employee?          @relation("ManagerToSubordinates", fields: [managerId], references: [id])
  subordinates      Employee[]         @relation("ManagerToSubordinates")
  team              String?
  branch            String? // Filial
  businessUnit      String? // Unidade de negÃ³cio
  hierarchicalLevel HierarchicalLevel?

  // ðŸ“Œ 6. Status do Colaborador
  status            EmployeeStatus     @default(ACTIVE)
  terminationReason String?            @db.Text
  terminationDate   DateTime?
  movements         EmployeeMovement[]
  vehicleTrips      VehicleTrip[]

  // ðŸ“Œ 7. Dados de Acesso ao Sistema
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])
  login  String? @unique

  // ðŸ“Œ 8. Anexos
  asos      ASO[]
  documents EmployeeDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employees")
}

model EmployeeMovement {
  id            String   @id @default(uuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type          String // PROMOTION, TRANSFER, SALARY_ADJUSTMENT, STATUS_CHANGE
  description   String   @db.Text
  previousValue String?
  newValue      String?
  date          DateTime @default(now())
  createdAt     DateTime @default(now())

  @@map("employee_movements")
}

model ASO {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       ASOType
  examDate   DateTime
  expiryDate DateTime
  result     String? // Ex: APTO, INAPTO
  fileUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("asos")
}

model EmployeeDocument {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name       String
  type       String? // Ex: RG, CPF, CTPS
  fileUrl    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("employee_documents")
}

// ============================================
// MÓDULO FISCAL – NF-e / NFS-e (2026)
// ============================================

enum StatusNota {
  PENDENTE
  PROCESSANDO
  AUTORIZADA
  REJEITADA
  CANCELADA
  DENEGADA
}

enum AmbienteNota {
  PRODUCAO
  HOMOLOGACAO
}

enum EventoSefazTipo {
  AUTORIZACAO
  CANCELAMENTO
  INUTILIZACAO
  CARTA_CORRECAO
  REJEICAO
}

enum WebhookEventoTipo {
  NOTA_AUTORIZADA
  NOTA_REJEITADA
  NOTA_CANCELADA
}

// Tabela principal da NF-e (mercadoria)
model NotaFiscal {
  id                 String         @id @default(uuid())
  numero             String         @unique
  serie              String
  chaveAcesso        String?        @unique
  protocolo          String?
  serviceOrderId     String?
  clientId           String
  createdById        String
  emitenteCnpj       String
  destinatarioCnpj   String
  valorBruto         Decimal        @db.Decimal(14, 2)
  valorLiquido       Decimal        @db.Decimal(14, 2)
  xmlAssinado        String?        @db.Text
  xmlAutorizado      String?        @db.Text
  pdfDanfeUrl        String?
  status             StatusNota     @default(PENDENTE)
  ambiente           AmbienteNota   @default(HOMOLOGACAO)
  // Split Payment: { valorRetido, aliquotaTotal, banco, chavePix }
  splitPayment       Json?
  motivoCancelamento String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  serviceOrder ServiceOrder?     @relation(fields: [serviceOrderId], references: [id])
  client       Client            @relation(fields: [clientId], references: [id])
  createdBy    User              @relation("CreatedNotasFiscais", fields: [createdById], references: [id])
  itens        NotaFiscalItem[]
  impostos     ImpostoRetido[]
  eventos      EventoSefaz[]
  webhooks     WebhookDispatch[]

  @@index([serviceOrderId])
  @@index([clientId])
  @@index([status])
  @@map("notas_fiscais")
}

model NotaFiscalItem {
  id             String     @id @default(uuid())
  notaId         String
  nota           NotaFiscal @relation(fields: [notaId], references: [id], onDelete: Cascade)
  productId      String
  product        Product    @relation(fields: [productId], references: [id])
  ncm            String
  descricao      String
  quantidade     Decimal    @db.Decimal(10, 3)
  valorUnitario  Decimal    @db.Decimal(14, 4)
  valorTotal     Decimal    @db.Decimal(14, 2)
  fabricadoNaZfm Boolean    @default(false)
  cfop           String     @default("5102")
  createdAt      DateTime   @default(now())

  @@index([notaId])
  @@map("nota_fiscal_itens")
}

// Impostos calculados, dual-regime 2026
model ImpostoRetido {
  id     String     @id @default(uuid())
  notaId String
  nota   NotaFiscal @relation(fields: [notaId], references: [id], onDelete: Cascade)

  // ─── Regime Legado ───────────────────────────────────────
  aliquotaIss    Decimal? @db.Decimal(6, 4)
  valorIss       Decimal? @db.Decimal(14, 4)
  aliquotaIcms   Decimal? @db.Decimal(6, 4)
  valorIcms      Decimal? @db.Decimal(14, 4)
  aliquotaPis    Decimal? @db.Decimal(6, 4)
  valorPis       Decimal? @db.Decimal(14, 4)
  aliquotaCofins Decimal? @db.Decimal(6, 4)
  valorCofins    Decimal? @db.Decimal(14, 4)

  // ─── Reforma Tributária 2026 ─────────────────────────────
  aliquotaCbs Decimal @db.Decimal(6, 4) // 0.9000 (%)
  valorCbs    Decimal @db.Decimal(14, 4)
  aliquotaIbs Decimal @db.Decimal(6, 4) // 0.1000 (%)
  valorIbs    Decimal @db.Decimal(14, 4)

  // ─── ZFM ─────────────────────────────────────────────────
  creditoPresumidoZfm Decimal? @db.Decimal(14, 4)
  beneficioZfmAtivo   Boolean  @default(false)

  // ─── Totais ──────────────────────────────────────────────
  totalImpostoLegado Decimal @db.Decimal(14, 4)
  totalImposto2026   Decimal @db.Decimal(14, 4)
  calculoPorFora     Boolean @default(true)

  createdAt DateTime @default(now())

  @@map("impostos_retidos")
}

// Eventos de ciclo de vida enviados / recebidos da SEFAZ
model EventoSefaz {
  id         String          @id @default(uuid())
  notaId     String
  nota       NotaFiscal      @relation(fields: [notaId], references: [id], onDelete: Cascade)
  tipo       EventoSefazTipo
  codigo     String // Código de retorno SEFAZ (ex: "100", "301")
  descricao  String
  protocolo  String?
  xmlEvento  String?         @db.Text
  xmlRetorno String?         @db.Text
  createdAt  DateTime        @default(now())

  @@map("eventos_sefaz")
}

// Despachos de webhook para o portal principal
model WebhookDispatch {
  id            String            @id @default(uuid())
  notaId        String
  nota          NotaFiscal        @relation(fields: [notaId], references: [id], onDelete: Cascade)
  evento        WebhookEventoTipo
  url           String
  payload       Json
  statusCode    Int?
  tentativas    Int               @default(0)
  sucesso       Boolean           @default(false)
  proxTentativa DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("webhook_dispatches")
}
